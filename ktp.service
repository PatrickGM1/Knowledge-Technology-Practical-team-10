[Unit]
Description=KTP Recipe Recommender (Streamlit)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/ktp/recipe_recommender
ExecStart=/var/www/ktp/.venv/bin/streamlit run main.py \
    --server.port=8501 \
    --server.address=127.0.0.1 \
    --server.headless=true
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
